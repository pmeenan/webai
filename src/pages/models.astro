---
import ModelManager from "../components/ModelManager";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Models"
  description="Discover, evaluate, download, import, verify, and manage local GGUF models in browser storage."
>
  <section aria-labelledby="models-title">
    <p class="eyebrow">Model discovery and acquisition</p>
    <h1 id="models-title" class="page-title">Models</h1>
    <p class="page-summary">
      Find browser-oriented GGUF models, compare exact revision-pinned artifacts, or use
      a repository ID or local files as an escape hatch. Downloads resume from durable
      bytes and install only after integrity checks pass.
    </p>
    <ModelManager client:load />
  </section>
</BaseLayout>
