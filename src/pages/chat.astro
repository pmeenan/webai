---
import ChatWorkbench from "../components/ChatWorkbench";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Chat"
  description="Chat locally with a downloaded GGUF on wllama or browser-managed Gemini Nano and inspect live response metrics."
>
  <section aria-labelledby="chat-title">
    <p class="eyebrow">Local runtime workbench</p>
    <h1 id="chat-title" class="page-title">Chat</h1>
    <p class="page-summary">
      Switch between a managed GGUF on wllama and Chrome's browser-managed Gemini Nano,
      stream a local response, and compare every timing or context measurement each
      runtime actually exposes.
    </p>
    <ChatWorkbench client:load />
  </section>
</BaseLayout>
