---
import ChatWorkbench from "../components/ChatWorkbench";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Chat"
  description="Run a downloaded GGUF locally with wllama and inspect live response metrics."
>
  <section aria-labelledby="chat-title">
    <p class="eyebrow">First local inference path</p>
    <h1 id="chat-title" class="page-title">Chat</h1>
    <p class="page-summary">
      Load a managed GGUF with independently configured WASM threads and WebGPU layer
      offload, stream a local response, and measure model load, TTFT, prefill, and decode
      throughput from the first message.
    </p>
    <ChatWorkbench client:load />
  </section>
</BaseLayout>
